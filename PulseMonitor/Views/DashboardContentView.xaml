<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PulseMonitor.ViewModels"
             xmlns:views="clr-namespace:PulseMonitor.Views"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="PulseMonitor.Views.DashboardContentView"
             x:DataType="viewModels:MainViewModel">
  <ScrollView>
    <VerticalStackLayout Spacing="12">
      <Border BackgroundColor="White"
              Stroke="{Binding BpmBorderColor}"
              StrokeThickness="2"
              StrokeShape="RoundRectangle 16"
              Padding="16">
        <VerticalStackLayout>
          <Label Text="BPM" FontAttributes="Bold" TextColor="#2C445A" />
          <Label Text="{Binding BpmDisplay}"
                 Margin="0,8,0,0"
                 FontSize="48"
                 FontAttributes="Bold"
                 TextColor="{Binding BpmTextColor}" />
        </VerticalStackLayout>
      </Border>

      <Border BackgroundColor="White"
              Stroke="{Binding SpO2BorderColor}"
              StrokeThickness="2"
              StrokeShape="RoundRectangle 16"
              Padding="16">
        <VerticalStackLayout>
          <Label Text="SpO2 (%)" FontAttributes="Bold" TextColor="#2C445A" />
          <Label Text="{Binding SpO2Display}"
                 Margin="0,8,0,0"
                 FontSize="48"
                 FontAttributes="Bold"
                 TextColor="{Binding SpO2TextColor}" />
        </VerticalStackLayout>
      </Border>

      <Border BackgroundColor="White"
              Stroke="#007AFF"
              StrokeThickness="2"
              StrokeShape="RoundRectangle 16"
              Padding="16">
        <VerticalStackLayout>
          <Label Text="Session Timer" FontAttributes="Bold" TextColor="#2C445A" />
          <Label Text="{Binding SessionTimerText}"
                 Margin="0,8,0,0"
                 FontSize="40"
                 FontAttributes="Bold"
                 TextColor="#007AFF" />
        </VerticalStackLayout>
      </Border>

      <Border BackgroundColor="White"
              Stroke="#DCE6EF"
              StrokeThickness="1"
              StrokeShape="RoundRectangle 16"
              Padding="12">
        <VerticalStackLayout Spacing="8">
          <Label Text="IR and Red Waveforms (8-second window)"
                 FontAttributes="Bold"
                 TextColor="#2C445A" />
          <skia:SKCanvasView x:Name="PpgCanvas" HeightRequest="260" PaintSurface="OnPaintPpgSurface" />
        </VerticalStackLayout>
      </Border>

      <!-- ECG Section -->
      <Border BackgroundColor="White"
              Stroke="#DCE6EF"
              StrokeThickness="1"
              StrokeShape="RoundRectangle 16"
              Padding="12">
        <VerticalStackLayout Spacing="8">
          <HorizontalStackLayout Spacing="10">
            <Label Text="ECG Waveform (Board B)" FontAttributes="Bold" TextColor="#2C445A" VerticalOptions="Center" />
            <Button Text="{Binding EcgConnectButtonText}" Command="{Binding ConnectEcgCommand}" HeightRequest="35" Padding="10,0" FontSize="12" />
            <Label Text="{Binding EcgConnectionStatus}" VerticalOptions="Center" FontSize="12" TextColor="Gray" />
          </HorizontalStackLayout>
          <Grid HeightRequest="200">
            <skia:SKCanvasView x:Name="EcgCanvas" PaintSurface="OnPaintSurface" />
            <!-- Lead Off Warning Overlay -->
            <Border BackgroundColor="#CCFF3B30"
                    IsVisible="{Binding IsEcgLeadOff}"
                    StrokeShape="RoundRectangle 8"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    Padding="20,10">
              <Label Text="{Binding EcgLeadOffText}" TextColor="White" FontAttributes="Bold" FontSize="18" />
            </Border>
          </Grid>
        </VerticalStackLayout>
      </Border>


      <Border BackgroundColor="White"
              Stroke="#DCE6EF"
              StrokeThickness="1"
              StrokeShape="RoundRectangle 12"
              Padding="10">
        <VerticalStackLayout Spacing="8">
          <Label Text="Event Log" FontAttributes="Bold" TextColor="#2C445A" />
          <CollectionView ItemsSource="{Binding EventLogEntries}" HeightRequest="190">
            <CollectionView.ItemTemplate>
              <DataTemplate>
                <Label Text="{Binding .}"
                       FontFamily="Courier New"
                       FontSize="12"
                       TextColor="#2C445A"
                       LineBreakMode="TailTruncation" />
              </DataTemplate>
            </CollectionView.ItemTemplate>
          </CollectionView>
        </VerticalStackLayout>
      </Border>
    </VerticalStackLayout>
  </ScrollView>
</ContentView>
